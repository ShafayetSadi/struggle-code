{
  "name": "struggle-ai-vscode",
  "displayName": "Struggle AI",
  "description": "A Socratic coding mentor that guides you through problems with questions, not answers. Requires @struggle-ai/cli installed globally.",
  "version": "0.1.0",
  "publisher": "TonmayHossainJifat",
  "author": "Struggle AI",
  "license": "MIT",
  "homepage": "https://github.com/ShafayetSadi/struggle-code#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShafayetSadi/struggle-code.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/ShafayetSadi/struggle-code/issues"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#111111",
    "theme": "dark"
  },
  "categories": [
    "Machine Learning",
    "Education",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding",
    "mentor",
    "socratic",
    "learning",
    "struggle"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:struggle.start"
  ],
  "contributes": {
    "commands": [
      {
        "command": "struggle.start",
        "title": "Struggle AI: Start Session"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "struggle",
          "title": "Struggle AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "struggle": [
        {
          "id": "struggle.trailView",
          "name": "Learning Trail"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node ./scripts/build.mjs",
    "build": "node ./scripts/build.mjs",
    "dev": "node ./scripts/build.mjs --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@struggle-ai/core": "0.1.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "vitest": "4.1.5"
  }
}
